import requests, urllib3
urllib3.disable_warnings()

HOST  = "https://your-qradar-host"
TOKEN = "your-api-token"

resp = requests.get(
    f"{HOST}/api/asset_model/properties",
    headers={
        "SEC": TOKEN,
        "Accept": "application/json",
        "Version": "12.0",
    },
    verify=False
)

for p in resp.json():
    print(f"  id: {p.get('id')}  |  name: {p.get('name')}  |  type: {p.get('data_type')}")
