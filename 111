import requests, urllib3
urllib3.disable_warnings()

HOST  = "https://your-qradar-host"
TOKEN = "your-api-token"

resp = requests.get(
    f"{HOST}/api/ariel/databases",
    headers={
        "SEC": TOKEN,
        "Accept": "application/json",
        "Version": "12.0",
    },
    verify=False
)

for db in resp.json():
    print(db)
