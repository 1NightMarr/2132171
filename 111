import requests, urllib3, json
urllib3.disable_warnings()

HOST  = "https://your-qradar-host"
TOKEN = "your-api-token"

# Спробуємо asset_model/properties — там список всіх можливих полів
resp = requests.get(
    f"{HOST}/api/asset_model/properties",
    headers={
        "SEC": TOKEN,
        "Accept": "application/json",
        "Version": "12.0",
    },
    verify=False
)

for p in resp.json():
    print(p.get("name"), "→ id:", p.get("id"))
