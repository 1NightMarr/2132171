import requests, urllib3
urllib3.disable_warnings()

HOST  = "https://your-qradar-host"
TOKEN = "your-api-token"

resp = requests.get(
    f"{HOST}/api/asset_model/assets",
    headers={
        "SEC": TOKEN,
        "Accept": "application/json",
        "Version": "12.0",
        "Range": "items=0-0"
    },
    verify=False
)

asset = resp.json()[0]
print("=== PROPERTIES ===")
for p in asset.get("properties", []):
    print(f"  {p.get('name')} → {p.get('value')}")
